  "keyFeatures": [
    "Multi-channel messaging: SMS, Viber, WhatsApp from one API",
    "Message flow fallback (e.g., try Viber first, fall back to SMS)",
    "Scheduled and time-windowed message delivery",
    "Delivery webhooks with HMAC payload signing",
    "Phone number verification (OTP) with offline proof support",
    "Batch sending up to 100 recipients per API call",
    "WhatsApp Business Partner onboarding API",
    "Credit and account management via REST API",
    "Inbox and message status polling",
    "Simple GET/POST endpoint for low-code integrations"
  ],
